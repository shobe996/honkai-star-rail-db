{
  "name": "honkai-star-rail-db",
  "version": "1.1.1",
  "description": "A type-safe database for Honkai: Star Rail characters and assets.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "husky",
    "lint": "./node_modules/.bin/eslint .",
    "lint:fix": "./node_modules/.bin/eslint . --fix",
    "format": "./node_modules/.bin/prettier --check .",
    "format:fix": "./node_modules/.bin/prettier --write .",
    "clean": "rm -rf dist",
    "build": "npm run clean && ./node_modules/.bin/tsc",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "npx prettier --write",
      "npx eslint --fix"
    ]
  },
  "keywords": [
    "honkai-star-rail",
    "hsr",
    "database",
    "dataset",
    "typescript"
  ],
  "author": "shobe996",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.11",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
